APP_NAME="Koro Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

# Database — only secrets allowed in .env (plus APP_KEY above).
# Integration API keys are stored encrypted in the database via Core module.
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=koro
DB_USERNAME=koro
DB_PASSWORD=koro

SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database

LOG_CHANNEL=stack
LOG_LEVEL=debug
